# HTTP server
PORT=3000

# Postgres connection string (names table + acme_account table)
DATABASE_URL=postgres://tinycloud_link:changeme@localhost:5432/tinycloud_link

# Cloudflare DNS provider (owns the *.local.tinycloud.link zone)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ACME (Let's Encrypt) account
ACME_EMAIL=ops@tinycloud.xyz
# Defaults to Let's Encrypt STAGING when unset. Set to the production directory
# only once the service has been validated end-to-end:
#   https://acme-v02.api.letsencrypt.org/directory
ACME_DIRECTORY=https://acme-staging-v02.api.letsencrypt.org/directory

# TEE attestation document (Phala dstack), optional outside of TEE deployments
ATTESTATION_DOCUMENT=
