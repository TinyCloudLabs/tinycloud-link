{
  "name": "@tinycloudlabs/tinycloud-link",
  "version": "0.1.0",
  "description": "tinycloud.link name + certificate control plane: DNS for *.local.tinycloud.link and brokered ACME DNS-01 cert issuance for local TinyCloud nodes",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx --test src/*.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@noble/curves": "^1.9.7",
    "acme-client": "^5.4.0",
    "hono": "^4.6.14",
    "multiformats": "^13.4.1",
    "node-forge": "^1.3.1",
    "pg": "^8.13.1",
    "viem": "^2.21.53"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-forge": "^1.3.11",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0"
  }
}
